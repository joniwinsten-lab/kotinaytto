# Kopioi `env.example` -> `.env` (web) ja täytä arvot.
# Android: kopioi `android-tv/local.properties.example` -> `android-tv/local.properties`.

# Supabase (julkinen anon-avain webille ja TV:lle)
# URL = https://<PROJECT_REF>.supabase.co  (sama kuin Dashboardissa)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# TV-lukutoken (SQL: select read_token from families limit 1;)
VITE_FAMILY_READ_TOKEN=

# Muokkauslinkkien tokenit (SQL: select slug, secret from editor_tokens;)
VITE_TOKEN_BEEN=
VITE_TOKEN_MAIJA=
VITE_TOKEN_JONI=
VITE_TOKEN_SHARED=

# Edge-funktiot (kuvan upload). Tyhjä = käytä VITE_SUPABASE_URL/functions/v1/...
VITE_FUNCTIONS_BASE=
